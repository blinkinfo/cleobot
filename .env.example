# =============================================================================
# CleoBot -- Environment Variables
# Copy this file to .env and fill in your values.
# On Railway/Render/Fly.io, set these directly in the platform dashboard.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram (required for notifications)
# Create a bot via @BotFather and get your chat ID via @userinfobot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# -----------------------------------------------------------------------------
# MEXC (optional -- public market data works without API keys)
# Only needed if you want authenticated endpoints (trading, account info)
# -----------------------------------------------------------------------------
MEXC_API_KEY=
MEXC_SECRET_KEY=

# -----------------------------------------------------------------------------
# Polymarket (required for trading)
# private_key: Ethereum private key of your trading wallet (hex, with or without 0x)
# funder_address: Your Polymarket proxy/funder wallet address
# signature_type:
#   0 = EOA (standard wallet)
#   1 = POLY_PROXY (Polymarket proxy wallet)
#   2 = POLY_GNOSIS_SAFE (default, recommended for Polymarket)
# -----------------------------------------------------------------------------
POLYMARKET_PRIVATE_KEY=0xyour_private_key_here
POLYMARKET_FUNDER_ADDRESS=0xyour_funder_address_here
POLYMARKET_SIGNATURE_TYPE=2

# -----------------------------------------------------------------------------
# Trading parameters (optional -- defaults shown)
# AUTO_TRADE_ENABLED=false means the bot runs in paper/signal-only mode
# -----------------------------------------------------------------------------
AUTO_TRADE_ENABLED=false
BASE_TRADE_SIZE=1.0
MAX_TRADE_SIZE=3.0
MAX_DAILY_LOSS=15.0
MAX_CONSECUTIVE_LOSSES=5

# -----------------------------------------------------------------------------
# System (optional -- defaults shown)
# DATA_DIR: where CleoBot stores the SQLite DB and trained models
#   Local:   ./data
#   Railway: /data  (mount a Volume at /data for persistence)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
DATA_DIR=./data
RETRAIN_HOUR_UTC=4
